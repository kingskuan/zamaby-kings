# PrivateFund Environment Variables
# Copy this to .env and fill in your values

# Your deployer wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Infura or Alchemy API key for Sepolia
INFURA_KEY=your_infura_key_here

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_key_here

# Zama Devnet URL (for local FHE testing)
ZAMA_DEVNET_URL=http://localhost:8545

# Deployed contract address (fill after deployment)
CONTRACT_ADDRESS=

# Auditor wallet address
AUDITOR_ADDRESS=

# Regulator wallet address  
REGULATOR_ADDRESS=
